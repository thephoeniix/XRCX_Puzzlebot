<launch>

    <let name="world" value="$(find-pkg-share puzzlebot_gazebo)/worlds/puzzlebot_world.world" />
    <let name= "puzzlebot_description_path" value="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml" />
    <let name= "gazebo_bridge_config_path" value="$(find-pkg-share puzzlebot_gazebo)/launch/puzzlebot_gazebo.launch.xml" />
    <let name= "gz_sim_launch_path" value="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py" />

    <let name="y_pose" value="1.35" />
    <let name= "x_pose" value="0.0" />

    <let name= "use_sim_time" default="true" />
    <let name= "headless" default="false" />


    <included if="$(not $(var headless)" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="--headless --verbose $(var world)"/>
    </included>

    <included if="$(var headless)" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="--headless --verbose $(var world)"/>
    </included>


    <included if="$(var puzzlebot_description_path)">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </included>

    <node pkg="ros_gz_sim" exec="create" output="screen" args="-name puzzlebot -topic robot_description -x $(var x_pose) -y $(var y_pose) -z 0.01 -Y 3.1416"/>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
        <param name="config_file" value="$(var gazebo_bridge_config_path)"/>
    </node>

</launch>