<launch>
    <let name="puzzlebot_gazebo_launch_path" value="$(find-pkg-share
    puzzlebot_gazebo)/launch/puzzlebot_gazebo.launch.xml" />
    <let name="nav2_core_launch_path" value="$(find-pkg-share
    nav2_bringup)/launch/nav2_core.launch.xml" />
    <let name="nav2_rviz_config_path" value="$(find-pkg-share
    puzzlebot_navigation2)/rviz/nav2.rviz" />


    <arg name="nav2_params_file" default="$(find-pkg-share 
    puzzlebot_navigation2)/config/nav2_params.yaml" />
    <arg name="map_path" default="$(find-pkg-share 
    puzzlebot_navigation2)/maps/map.yaml" />
    <arg name="use_sim_time" default="true" />
    <arg name="headless" default="true" />

    <include file="$(var puzzlebot_gazebo_launch_path)" >
        <arg name="headless" value="$(var headless)" /> 
    </include>

    <include file="$(var nav2_core_launch_path)" >
        <arg name="use_sim_time" value="$(var use_sim_time)" />
        <arg name="nav2_params_file" value="$(var nav2_params_file)" />
        <arg name="map" value="$(var map_path)" />
        <arg name="rviz_config_path" value="$(var nav2_rviz_config_path)" />   
    </include>

</launch>