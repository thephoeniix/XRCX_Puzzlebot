<launch>    
    <let name="nav2_bringup_launch_path" value="$(find-pkg-share nav2_bringup)/launch/bringup_launch.py" />
    <arg name="map_path" default="$(find-pkg-share puzzlebot_navigation2)/maps/map_maze.yaml" />
    <arg name="nav2_params_file" default="$(find-pkg-share puzzlebot_navigation2)/config/nav2_params.yaml" />
    <arg name="rviz_config_path" default="$(find-pkg-share puzzlebot_navigation2)/rviz/nav2.rviz" />
    <arg name="use_sim_time" default="false" />
    
    <include file="$(var nav2_bringup_launch_path)">
        <arg name="map" value="$(var map_path)" />
        <arg name="use_sim_time" value="$(var use_sim_time)" />
        <arg name="params_file" value="$(var nav2_params_file)" />
    </include>
    
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>

</launch>
