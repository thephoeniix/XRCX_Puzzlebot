<?xml version="1.0"?>
<!-- Entry point for the puzzlebot URDF -->
<robot name="puzzlebot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="prefix" default="" />

  <xacro:include filename="$(find puzzlebot_description)/urdf/puzzlebot_base.urdf.xacro"/>
  <xacro:include filename="$(find puzzlebot_description)/urdf/puzzlebot_control.xacro"/>
  <xacro:puzzlebot_control prefix="$(arg prefix)"/>

</robot>


