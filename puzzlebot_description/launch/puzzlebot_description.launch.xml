<launch>
    <arg name="rviz" default="false" />
    <arg name="gazebo" default="false" />
    <arg name="joint_gui" default="false" />
    <arg name="use_sim_time" default="false" />

    <let name="urdf_path" value="$(find-pkg-share puzzlebot_description)/urdf/puzzlebot.xacro" />
    <let name="rviz_config_path" value="$(find-pkg-share puzzlebot_description)/rviz/puzzlebot_description.rviz" />
    <let name="gazebo_path" value="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py" /> 
    <!-- Este es para gazebo garden, instalar gazebo garden con
    las especificaciones de la primer actividad de juanma ledesma -->

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="use_sim_time" value="$(var use_sim_time)" />
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="rviz2" exec="rviz2" output="screen" name="rviz2" if="$(var rviz)" args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>

    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui" if="$(var joint_gui)" output="screen" />

    <include if="$(var gazebo)" file="$(var gazebo_path)">
        <arg name="gz_args" value="empty.sdf -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create" name="spawn_entity" output="screen" if="$(var gazebo)" args="-name puzzlebot -topic robot_description" />

</launch>